{
  "id": "perch_v2",
  "display_name": "Perch v2",
  "short_code": "P2",
  "version": "2.0",
  "domain": "taxon",

  "model": {
    "url": "https://huggingface.co/ernensbjorn/perch-v2-int8-tflite/resolve/main/perch_v2_fp16.tflite",
    "md5": null,
    "runtime": "tflite",
    "filename": "model.tflite"
  },

  "input": {
    "sample_rate_hz": 32000,
    "window_ms": 5000,
    "samples": 160000,
    "format": "mean_centre_peak_norm",
    "target_peak": 0.25
  },

  "output": {
    "class_count": 14795,
    "primary_output_index": 3,
    "embedding_output_index": 0,
    "post_process": "sigmoid_logit_clamp",
    "logit_clamp_low": 0.0,
    "logit_clamp_high": 15.0
  },

  "calibration": null,

  "labels": {
    "url": "https://raw.githubusercontent.com/pcmoan70/Aibirder_Models/main/perch_v2/perch_v2_labels.csv",
    "md5": null,
    "filename": "labels.csv",
    "has_header": true,
    "columns": null,
    "delimiter": "auto",
    "key_column": "scientific_name",
    "class_idx_column": null,
    "class_idx_start": 0
  },

  "stride_percent_default": 50,
  "stall_tolerance_ms": 60000
}
